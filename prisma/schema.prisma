datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  username     String   @unique
  passwordHash String   @map("password_hash")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  arcs          Arc[]
  sessions      Session[]
  conversations Conversation[]

  @@map("users")
}

model Arc {
  id           String     @id @default(cuid())
  name         String
  status       ArcStatus  @default(OFFLINE)
  agentToken   String     @unique @map("agent_token")
  userId       String     @map("user_id")
  instanceId   String?    @map("instance_id")
  instanceIp   String?    @map("instance_ip")
  instanceState String?   @map("instance_state")
  lastSeenAt   DateTime?  @map("last_seen_at")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages      Message[]
  conversations Conversation[]

  @@index([userId])
  @@map("arcs")
}

enum ArcStatus {
  ONLINE
  OFFLINE
  ERROR
}

model Conversation {
  id        String   @id @default(cuid())
  name      String   @default("New Chat")
  userId    String   @map("user_id")
  arcId     String   @map("arc_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  arc      Arc       @relation(fields: [arcId], references: [id], onDelete: Cascade)
  messages Message[]

  @@index([userId, updatedAt])
  @@map("conversations")
}

model Message {
  id             String      @id @default(cuid())
  role           MessageRole
  content        String
  toolName       String?     @map("tool_name")
  toolData       Json?       @map("tool_data")
  arcId          String      @map("arc_id")
  conversationId String      @map("conversation_id")
  createdAt      DateTime    @default(now()) @map("created_at")

  arc          Arc          @relation(fields: [arcId], references: [id], onDelete: Cascade)
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@map("messages")
}

enum MessageRole {
  USER
  ARC
  SYSTEM
}

model Session {
  id           String   @id @default(cuid())
  userId       String   @map("user_id")
  refreshToken String   @unique @map("refresh_token")
  userAgent    String?  @map("user_agent")
  expiresAt    DateTime @map("expires_at")
  createdAt    DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}
