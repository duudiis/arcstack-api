DATABASE_URL=postgresql://arcstack:arcstack_dev@localhost:5432/arcstack
REDIS_URL=redis://localhost:6379
JWT_SECRET=change-me-jwt-secret-at-least-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-at-least-32-chars
OPENAI_API_KEY=sk-your-openai-api-key
PORT=4000
HOST=0.0.0.0
NODE_ENV=development
FRONTEND_URL=http://localhost:3000
COOKIE_DOMAIN=localhost

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# AWS EC2 provisioning
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_AMI_ID=ami-0abcdef1234567890
AWS_SECURITY_GROUP_ID=sg-0abcdef1234567890
AWS_SUBNET_ID=subnet-0abcdef1234567890
AWS_KEY_PAIR_NAME=arcstack-key
AWS_INSTANCE_TYPE=t2.micro
AGENT_WS_URL=ws://localhost:4000
AGENT_REPO_URL=https://github.com/duudiis/arcstack-agent.git
